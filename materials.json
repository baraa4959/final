  "quotes": [
    {
      "type": "quote",
      "text": "لا تنسونا من دعائكم لعلكم أقرب إلى الله منزلة"
    },
    {
      "type": "hadith",
      "text": "احرص على ما ينفعك، واستعن بالله ولا تعجز"
    },
    {
      "type": "ayah",
      "text": "رب اشرح لي صدري ويسر لي أمري واحلل عقدة من لساني"
    },
    {
      "type": "ayah",
      "text": "(وَقُل رَبِّ زِدني عِلمًا)"
    },
    {
      "type": "ayah",
      "text": "(رَبِّ هَبْ لِي حُكْمًا وَأَلْحِقْنِي بِالصَّالِحِينَ)"
    },
    {
      "type": "hadith",
      "text": "(من خرج في طلب العلم، كان في سبيل الله حتى يرجع)"
    },
    {
      "type": "hadith",
      "text": "سبحان الله وبحمده، سبحان الله العظيم"
    },
    {
      "type": "poetry",
      "text": "وَما يُغنيكَ تَشيِيدُ المَباني إِذا بِالجَهلِ نَفسَكَ قَد هَدَمتا"
    },
    {
      "type": "poetry",
      "text": "جَعَلتَ المالَ فَوقَ العِلمِ جَهلاً لَعَمرُكَ في القَضيَّةِ ماعَدَلتا"
    },
    {
      "type": "poetry",
      "text": "فَرَأسُ العِلمِ تَقوى اللَهِ حَقّاً وَلَيسَ بِأَن يُقال لَقَد رَأَستا"
    },
    {
      "type": "poetry",
      "text": "إِذا ما لَم يُفِدكَ العِلمُ خَيراً فَخَيرٌ مِنهُ أَن لَو قَد جَهِلتا"
    },
    {
      "type": "ayah",
      "text": "(وَقُلِ اعْمَلُوا فَسَيَرَى اللَّهُ عَمَلَكُمْ وَرَسُولُهُ وَالْمُؤْمِنُونَ)"
    },
    {
      "type": "ayah",
      "text": "(رَبَّنَا أَفْرِغْ عَلَيْنَا صَبْرًا وَتَوَفَّنَا مُسْلِمِينَ)"
    },
    {
      "type": "ayah",
      "text": "(رَبِّ أَوْزِعْنِي أَنْ أَشْكُرَ نِعْمَتَكَ الَّتِي أَنْعَمْتَ عَلَيَّ)"
    },
    {
      "type": "ayah",
      "text": "(إِنَّمَا يُوَفَّى الصَّابِرُونَ أَجْرَهُم بِغَيْرِ حِسَابٍ)"
    },
    {
      "type": "ayah",
      "text": "(لِلَّذِينَ أَحْسَنُوا فِي هَٰذِهِ الدُّنْيَا حَسَنَةٌ)"
    },
    {
      "type": "ayah",
      "text": "(إِنَّمَا يَخْشَى اللَّهَ مِنْ عِبَادِهِ الْعُلَمَاءُ)"
    }
  ]
}
